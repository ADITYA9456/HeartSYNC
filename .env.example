# =============================================================================
# CoupleSpace — environment variables (PLACEHOLDERS ONLY)
# Copy to `.env.local` for development and fill in real values.
# NEVER commit real secrets. `.env*` is git-ignored (except this file).
# =============================================================================

# ---- App ----
NODE_ENV=development
# The final public origin. Used for cookies, OAuth redirects, FCM, sockets.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Port for the custom Socket.IO + Next server.
PORT=3000

# ---- Auth / JWT ----
# 32+ char random string. Generate: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# ---- Supabase (Postgres data store) ----
# Project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# SERVICE-ROLE key — SERVER ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Anon key (safe for the browser; currently unused but kept for completeness).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---- Cloudinary (media) ----
CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_FOLDER=couplespace

# ---- Gemini (AI Copilot) ----
GEMINI_API_KEY=your-gemini-api-key

# ---- Google OAuth + YouTube Data API v3 ----
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Must match a Redirect URI registered in Google Cloud Console.
YT_MUSIC_REDIRECT_URI=http://localhost:3000/api/youtube/callback
# Optional: API key for unauthenticated YouTube Data API search.
YOUTUBE_API_KEY=your-youtube-data-api-key

# ---- Firebase Cloud Messaging (web push) ----
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
# Web Push certificate key pair (Firebase console > Cloud Messaging).
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-public-key

# ---- Firebase Admin (server push) ----
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Keep the literal \n escapes; the app converts them to newlines.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
